{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "site": "juh-residency",
    "public": "public",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/admin",
        "destination": "/admin.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "auth": {
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "JUH Dashboard",
        "supportEmail": "hussainalhashem99@gmail.com"
      }
    }
  }
}